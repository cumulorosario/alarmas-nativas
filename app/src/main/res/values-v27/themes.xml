<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- En API 27+ podemos agregar showWhenLocked y turnScreenOn como atributos del tema -->
    <style name="Theme.VigiaIndustrial.FullScreen" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowShowWhenLocked">true</item>
        <item name="android:windowTurnScreenOn">true</item>
    </style>
</resources>
